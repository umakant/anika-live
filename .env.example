# Admin login (required in production)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Session signing secret (required in production)
AUTH_SECRET=change-me-to-a-random-32-char-string

# Root directory for live stream data (production: /var/www/apps/anika-live/live-data)
LIVE_DATA_ROOT=/var/www/apps/anika-live/live-data

# Next.js app port (use 3010 on shared servers — 3000 is often taken)
PORT=3010
HOSTNAME=0.0.0.0

# Cloudinary — use ONE of these options:

# Option A (recommended): copy from Cloudinary dashboard → API Keys
CLOUDINARY_URL=cloudinary://836594361147136:YOUR_API_SECRET@dlyaexxhi

# Option B: separate variables (must match CLOUDINARY_URL exactly)
# CLOUDINARY_CLOUD_NAME=dlyaexxhi
# CLOUDINARY_API_KEY=836594361147136
# CLOUDINARY_API_SECRET=your-api-secret

CLOUDINARY_FOLDER=anika-live/videos
# Create an UNSIGNED preset in Cloudinary: Settings → Upload → Upload presets
CLOUDINARY_UPLOAD_PRESET=anika_live_unsigned

# FFmpeg paths (use apt version, NOT snap — snap breaks under PM2)
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
