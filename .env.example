# Admin login (required in production)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Session signing secret (required in production)
AUTH_SECRET=6646693c7134019f7b39ab17a715640e14c634c41bccfed21dc05bb5fc7ad56a

# Root directory for live stream data (production: /var/www/apps/anika-live/live-data)
LIVE_DATA_ROOT=/var/www/apps/anika-live/live-data

# Next.js app port (use 3010 on shared servers — 3000 is often taken)
PORT=3010
HOSTNAME=0.0.0.0

# Optional: override individual paths (defaults derive from LIVE_DATA_ROOT)
# VIDEOS_DIR=/var/live/anika/videos
# PROCESSED_DIR=/var/live/anika/processed
# PLAYLIST_FILE=/var/live/anika/playlist.txt
# DATA_DIR=/var/live/anika/data

# Cloudinary (required for video uploads)
CLOUDINARY_CLOUD_NAME=dlyaexxhl
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=anika-live/videos
# Recommended for browser uploads — create an UNSIGNED preset in Cloudinary (Settings → Upload → Upload presets)
CLOUDINARY_UPLOAD_PRESET=anika_live_unsigned
